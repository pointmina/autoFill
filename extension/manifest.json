{
  "manifest_version": 3,
  "name": "자소서 자동입력",
  "version": "0.1.0",
  "description": "채용 사이트 자소서 폼에 등록한 개인정보를 자동으로 입력하는 확장 프로그램",
  "action": {
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html",
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"]
}
